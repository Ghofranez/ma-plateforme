# .snyk — Fichier de politique Snyk
# Ce fichier liste les vulnérabilités à ignorer car :
# - elles viennent de dépendances externes (nuclei) qu'on ne contrôle pas
# - ou elles ne s'appliquent pas à notre environnement (Alpine vs Debian)
version: v1.25.0
ignore:
  # ══════════════════════════════════════════════════════════
  # NUCLEI — OpenTelemetry
  # ══════════════════════════════════════════════════════════
  SNYK-GOLANG-GOOPENTELEMETRYIOOTELPROPAGATION-15928420:
    - '*':
        reason: CVE dans nuclei (OpenTelemetry) — correction dépend de nuclei upstream
        expires: 2026-12-31T00:00:00.000Z
  SNYK-GOLANG-GOOPENTELEMETRYIOOTELINTERNALGLOBAL-15928418:
    - '*':
        reason: CVE dans nuclei (OpenTelemetry) — correction dépend de nuclei upstream
        expires: 2026-12-31T00:00:00.000Z

  # ══════════════════════════════════════════════════════════
  # DEBIAN — Non applicable (image Alpine)
  # ══════════════════════════════════════════════════════════
  SNYK-DEBIAN13-GNUTLS28-16344302:
    - '*':
        reason: CVE Debian 13 — notre image utilise Alpine, non concerné
        expires: 2026-12-31T00:00:00.000Z
  SNYK-DEBIAN13-GNUTLS28-16344314:
    - '*':
        reason: CVE Debian 13 — notre image utilise Alpine, non concerné
        expires: 2026-12-31T00:00:00.000Z

  # ══════════════════════════════════════════════════════════
  # NUCLEI — go-git et golang.org/x/net
  # ══════════════════════════════════════════════════════════
  SNYK-GOLANG-GOLANGORGXNETHTTP2-16535157:
    - '*':
        reason: CVE dans nuclei (golang.org/x/net) — correction dépend de nuclei upstream
        expires: 2026-12-31T00:00:00.000Z
  SNYK-GOLANG-GITHUBCOMGOGITGOGITV5PLUMBINGTRANSPORTHTTP-16109639:
    - '*':
        reason: CVE dans nuclei (go-git transport) — correction dépend de nuclei upstream
        expires: 2026-12-31T00:00:00.000Z
  SNYK-GOLANG-GITHUBCOMGOGITGOGITV5PLUMBINGOBJECT-16638689:
    - '*':
        reason: CVE dans nuclei (go-git object) — correction dépend de nuclei upstream
        expires: 2026-12-31T00:00:00.000Z

  # ══════════════════════════════════════════════════════════
  # NUCLEI — mholt/archiver/v3 (bibliothèque abandonnée)
  # Aucun fix disponible upstream — zip slip non exploitable
  # dans notre contexte (nuclei traite ses propres archives)
  # ══════════════════════════════════════════════════════════
  SNYK-GOLANG-GITHUBCOMMHOLTARCHIVERV3-9689907:
    - '*':
        reason: >
          mholt/archiver/v3 abandonné, pas de fix upstream,
          utilisé uniquement par nuclei en interne
        expires: 2026-12-31T00:00:00.000Z

